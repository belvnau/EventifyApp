<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutNotificationItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical">

    <androidx.cardview.widget.CardView
        android:id="@+id/cvNotifIconBg"
        android:layout_width="40dp"
        android:layout_height="40dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/colorOrangeSoft">

        <ImageView
            android:id="@+id/ivNotificationIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_notification"
            app:tint="@color/colorOrange"
            android:contentDescription="Notification Icon" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/tvNotificationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event Tertarik"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNotificationMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Kamu telah menyukai event Artket 05."
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvNotificationTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="2 jam yang lalu"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Optional dot to show unread notification -->
    <View
        android:id="@+id/viewNotifUnreadDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_dot_unread"
        android:visibility="gone"
        android:layout_marginEnd="8dp" />

    <!-- Delete single notification button -->
    <ImageButton
        android:id="@+id/btnDeleteNotification"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="@color/colorTextSecondary"
        android:contentDescription="Delete Notification"
        android:focusable="false"
        android:clickable="true" />
</LinearLayout>
