<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="top">

        <!-- Avatar circular image -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivNotificationAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/img_avatar_default"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner50"
            android:contentDescription="Avatar" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp">

            <!-- Message content containing bold sender name -->
            <TextView
                android:id="@+id/tvNotificationMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#19252B"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"
                android:text="Antonio Lee started following you" />

            <!-- Action buttons container (Reject / Accept) -->
            <LinearLayout
                android:id="@+id/layoutActionButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnReject"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="Reject"
                    android:textColor="#FF6B35"
                    android:backgroundTint="#FEEAE6"
                    android:textSize="11sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp" />

                <Button
                    android:id="@+id/btnAccept"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="Accept"
                    android:textColor="@color/white"
                    android:backgroundTint="#FF6B35"
                    android:textSize="11sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="18dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right container: Time + Unread indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvNotificationTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#9E9E9E"
                android:textSize="10sp"
                android:text="Just now" />

            <!-- Optional dot to show unread notification indicator -->
            <View
                android:id="@+id/viewNotifUnreadDot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_dot_unread"
                android:layout_marginTop="6dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
